// SMECC2E — PostgreSQL (see DATABASE_URL in .env)
// Run: npx prisma migrate dev --name init
//      npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

// prisma/schema.prisma
datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  COORDINATOR
  REVIEWER
  ADMINISTRATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProgramType {
  MASTER
  DOCTORATE
}

/// Matches `ApplicationStatus` in lib/application-types.ts
enum ScholarshipApplicationStatus {
  draft
  pending
  under_review
  evaluation
  interview
  final_evaluation
  offered
  reserved
  approved
  rejected
  pre_departure
}

/// One row per scholarship application (all form fields + workflow metadata).
/// File fields store object keys or URLs once uploads are wired to object storage.
model Applicant {
  id        String @id @default(cuid())
  /// Human-readable reference, e.g. APP-2026-0001 (set by app when submitting)
  publicId  String? @unique @map("public_id")

  status       ScholarshipApplicationStatus @default(draft)
  /// Last completed wizard step (1–18) while status is draft
  currentPage  Int?                         @map("current_page")
  submittedAt  DateTime?                    @map("submitted_at")
  createdAt    DateTime                     @default(now()) @map("created_at")
  updatedAt    DateTime                     @updatedAt @map("updated_at")

  // --- Section 2–4: Registration & personal ---
  email                   String
  nationality             String
  countryOfResidence      String  @map("country_of_residence")
  region                  String
  typeOfMobility          String  @map("type_of_mobility")
  preferredHostInstitution String @map("preferred_host_institution")
  proposedAcademicProgramme String @map("proposed_academic_programme")
  thematicArea            String @map("thematic_area")
  surname                 String
  firstName               String  @map("first_name")
  middleName              String  @default("") @map("middle_name")
  gender                  String
  dateOfBirth             String  @map("date_of_birth")
  stateProvince           String  @map("state_province")
  homeAddress             String  @map("home_address") @db.Text
  personalEmail           String  @map("personal_email")
  phoneNumber             String  @map("phone_number")
  linkedinUrl             String  @default("") @map("linkedin_url")
  socialMediaUrl          String  @default("") @map("social_media_url")
  passportOrIdNumber      String  @map("passport_or_id_number")
  profileUploaded         Boolean @default(false) @map("profile_uploaded")

  // --- Section 4: uploads (filenames / storage keys) ---
  passportFileName              String? @map("passport_file_name")

  // --- Section 5: disability ---
  belongsToDisadvantagedGroup   String  @map("belongs_to_disadvantaged_group")
  disadvantagedFinancially      Boolean @default(false) @map("disadvantaged_financially")
  disadvantagedDisability         Boolean @default(false) @map("disadvantaged_disability")
  disadvantagedRefugee            Boolean @default(false) @map("disadvantaged_refugee")
  disadvantagedConflict         Boolean @default(false) @map("disadvantaged_conflict")
  disadvantagedMinority         Boolean @default(false) @map("disadvantaged_minority")
  disadvantagedOther            Boolean @default(false) @map("disadvantaged_other")
  disadvantagedOtherSpecify     String  @default("") @map("disadvantaged_other_specify")
  disadvantagedDocFileName      String? @map("disadvantaged_doc_file_name")

  // --- Section 6: education ---
  eduBachelor                   Boolean @default(false) @map("edu_bachelor")
  eduMaster                     Boolean @default(false) @map("edu_master")
  eduPhd                        Boolean @default(false) @map("edu_phd")
  bachelorProgrammeUniversity   String  @default("") @map("bachelor_programme_university")
  bachelorCgpa                  String  @default("") @map("bachelor_cgpa")
  masterProgrammeUniversity     String  @default("") @map("master_programme_university")
  masterCgpa                    String  @default("") @map("master_cgpa")
  academicCertificatesFileName String? @map("academic_certificates_file_name")
  academicTranscriptsFileName   String? @map("academic_transcripts_file_name")

  // --- Section 7: credit-seeking registration ---
  currentlyEnrolledInDegree     String  @default("") @map("currently_enrolled_in_degree")
  registrationNumber            String  @default("") @map("registration_number")
  proofOfRegistrationFileName   String? @map("proof_of_registration_file_name")
  proofOfCourseworkFileName     String? @map("proof_of_coursework_file_name")

  // --- Section 8–9: profile & motivation ---
  whyApplyingScholarship          String @default("") @map("why_applying_scholarship") @db.Text
  cvFileName                      String? @map("cv_file_name")
  publicationsFileName            String? @map("publications_file_name")
  backgroundThematicAlignment     String @default("") @map("background_thematic_alignment") @db.Text
  scholarshipCareerGoals          String @default("") @map("scholarship_career_goals") @db.Text
  africaCleanEnergyContribution   String @default("") @map("africa_clean_energy_contribution") @db.Text

  // --- Section 10: research / study plan ---
  studyResearchPlanFileName       String? @map("study_research_plan_file_name")
  researchProposalFileName        String? @map("research_proposal_file_name")

  // --- Section 11: traineeship ---
  traineePreferredIndustrySector  String @default("") @map("trainee_preferred_industry_sector")
  traineeshipRelevantSkills         String @default("") @map("traineeship_relevant_skills") @db.Text
  traineeshipCareerInterestArea     String @default("") @map("traineeship_career_interest_area") @db.Text
  traineeshipCurrentProgrammeType   String @default("") @map("traineeship_current_programme_type")
  traineeshipCurrentPosition        String @default("") @map("traineeship_current_position")

  // --- Section 12: staff mobility ---
  staffOrganizationsWorkedWith      String @default("") @map("staff_organizations_worked_with") @db.Text
  staffCurrentRankPosition          String @default("") @map("staff_current_rank_position")
  staffYearsOfExperience            String @default("") @map("staff_years_of_experience")
  staffMobilityPurpose              String @default("") @map("staff_mobility_purpose") @db.Text
  staffProposedWorkPlan             String @default("") @map("staff_proposed_work_plan") @db.Text
  staffExpectedBenefits             String @default("") @map("staff_expected_benefits") @db.Text

  // --- Section 13: language ---
  homeInstructionLanguage           String @default("") @map("home_instruction_language")
  hasLanguageProficiencyCertificate String @default("") @map("has_language_proficiency_certificate")
  languageCertificateFileName       String? @map("language_certificate_file_name")

  // --- Section 14: references ---
  referee1Name            String @default("") @map("referee1_name")
  referee1Relationship      String @default("") @map("referee1_relationship")
  referee1Position        String @default("") @map("referee1_position")
  referee1Institution     String @default("") @map("referee1_institution")
  referee1Email           String @default("") @map("referee1_email")
  referee1Phone           String @default("") @map("referee1_phone")
  referee2Name            String @default("") @map("referee2_name")
  referee2Relationship    String @default("") @map("referee2_relationship")
  referee2Position        String @default("") @map("referee2_position")
  referee2Institution     String @default("") @map("referee2_institution")
  referee2Email           String @default("") @map("referee2_email")
  referee2Phone           String @default("") @map("referee2_phone")
  referenceLettersFileName String? @map("reference_letters_file_name")

  // --- Section 15: additional documents ---
  graduateAdmissionProofFileName      String? @map("graduate_admission_proof_file_name")
  staffEmploymentProofFileName        String? @map("staff_employment_proof_file_name")
  staffHostCommitmentLetterFileName   String? @map("staff_host_commitment_letter_file_name")
  medicalFitnessDeclarationFileName   String? @map("medical_fitness_declaration_file_name")

  // --- Section 16: previous scholarship ---
  previousIntraAfricaScholarship           String @default("") @map("previous_intra_africa_scholarship")
  previousScholarshipDeclarationFileName   String? @map("previous_scholarship_declaration_file_name")

  // --- Section 17: declaration & consent ---
  declarationCertified     Boolean @default(false) @map("declaration_certified")
  dataProtectionConsent    Boolean @default(false) @map("data_protection_consent")
  applicantSignature       String  @default("") @map("applicant_signature")

  // --- Next of kin (Section 4) ---
  nextOfKinName            String @default("") @map("next_of_kin_name")
  nextOfKinWhatsapp         String @default("") @map("next_of_kin_whatsapp")
  nextOfKinEmail            String @default("") @map("next_of_kin_email")
  nextOfKinRelationship     String @default("") @map("next_of_kin_relationship")

  @@index([email])
  @@index([status])
  @@index([submittedAt])
  @@map("applicants")
}

/// Dashboard / coordination team member
model User {
  id        String     @id @default(cuid())
  /// Human-readable id, e.g. USR-001
  publicId  String     @unique @map("public_id")
  name         String
  email        String     @unique
  phoneNumber  String     @map("phone_number")
  /// Bcrypt hash — never expose via API
  passwordHash String     @map("password_hash")
  institution      String
  profileImageUrl  String?  @map("profile_image_url")
  role             UserRole   @default(COORDINATOR)
  status       UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

/// African region grouping for applicant registration
model Region {
  id        String   @id @default(cuid())
  /// URL-safe key derived from name, e.g. western-africa
  slug      String   @unique
  name      String   @unique
  countries String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("regions")
}

/// SMECC2E host university / institution
model University {
  id         String   @id @default(cuid())
  /// URL-safe key derived from name
  slug       String   @unique
  name           String   @unique
  thematicAreas  String[]  @default([]) @map("thematic_areas")
  programs       Program[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("universities")
}

/// Academic programme offered by a host institution
model Program {
  id                   String      @id @default(cuid())
  universityId         String      @map("university_id")
  country              String
  type                 ProgramType
  name                 String
  thematicArea         String      @map("thematic_area")
  accreditationDetails String      @map("accreditation_details")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, name, type])
  @@map("programs")
}

/// One-time email verification link for application registration (stage 2)
model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

/// Applicant emails that completed verification (survives server restarts)
model VerifiedApplicantEmail {
  email      String   @id
  verifiedAt DateTime @default(now()) @map("verified_at")

  @@map("verified_applicant_emails")
}
